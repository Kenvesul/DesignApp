# DesignApp Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Flask session encryption key — REQUIRED in production (min 32 random characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DESIGNAPP_SECRET=dev-secret-change-in-production

# Flask debug mode (set to 0 in production)
FLASK_DEBUG=1

# Gunicorn workers (production only)
WORKERS=4

# Internal port
PORT=5000

# CORS origin for React dev server (production: your domain)
CORS_ORIGIN=http://localhost:5173

# Production domain (used by Docker Compose / Nginx)
DOMAIN=localhost
